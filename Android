proxy-groups:
- name: 🚀 智选节点
  type: smart
  include-all: true
  uselightgbm: true
  collectdata: false
  strategy: sticky-sessions
  interval: 300
  tolerance: 30

- name: 🤖 AI服务
  type: select
  proxies:
  - 🚀 智选节点
  - 🇭🇰 香港
  - 🇹🇼 台湾
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - 🇺🇸 美国

- name: 📺 港台番剧
  type: select
  proxies:
  - DIRECT
  - 🚀 智选节点
  - 🇭🇰 香港
  - 🇹🇼 台湾
  - 🇸🇬 新加坡

- name: 🔍 Google
  type: select
  proxies:
  - 🚀 智选节点
  - 🇭🇰 香港
  - 🇹🇼 台湾
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - 🇺🇸 美国

- name: 🎬 国外流媒体
  type: select
  proxies:
  - 🚀 智选节点
  - 🇭🇰 香港
  - 🇹🇼 台湾
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - 🇺🇸 美国

- name: 💬 国外社交媒体
  type: select
  proxies:
  - 🇺🇸 美国
  - 🇭🇰 香港
  - 🇹🇼 台湾
  - 🇸🇬 新加坡
  - 🇯🇵 日本

- name: 🌐 Final
  type: select
  proxies:
  - DIRECT
  - 🚀 智选节点
  - 🇭🇰 香港
  - 🇹🇼 台湾
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - 🇺🇸 美国

- name: 🇭🇰 香港
  type: smart
  uselightgbm: true
  collectdata: false
  strategy: sticky-sessions
  interval: 300
  tolerance: 30
  include-all: true
  filter: ^(.*)(香港|HK|Hong|hk|澳门)+(.*)$

- name: 🇹🇼 台湾
  type: smart
  uselightgbm: true
  collectdata: false
  strategy: sticky-sessions
  interval: 300
  tolerance: 30
  include-all: true
  filter: ^(.*)(台|TW|Tai)+(.*)$
  
- name: 🇸🇬 新加坡
  type: smart
  uselightgbm: true
  collectdata: false
  strategy: sticky-sessions
  interval: 300
  tolerance: 30
  include-all: true
  filter: ^(.*)(新加坡|狮城|SG|Singapore)+(.*)$

- name: 🇯🇵 日本
  type: smart
  uselightgbm: true
  collectdata: false
  strategy: sticky-sessions
  interval: 300
  tolerance: 30
  include-all: true
  filter: ^(.*)(日本|JP|韩|Japan)+(.*)$

- name: 🇺🇸 美国
  type: smart
  uselightgbm: true
  collectdata: false
  strategy: sticky-sessions
  interval: 300
  tolerance: 30
  include-all: true
  filter: ^(.*)(美国|US|USA|United States|States|American|Los Angeles|San Jose|Seattle|Chicago|Dallas|Silicon Valley)+(.*)$


